server:
  port: 8081

spring:
  application:
    name: user-ms
  datasource:
    url: url_database
    username: username
    password: password
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect

jwt:
  private_key: chave-privada
  public_key: chave-publica
